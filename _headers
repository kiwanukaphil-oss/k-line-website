# K-LINE MEN — Netlify cache + security headers
# Docs: https://docs.netlify.com/routing/headers/
#
# Strategy: aggressive caching for content-stable assets (images, favicons,
# the OG card), short cache for HTML so site updates show up promptly. CSS
# and JS get a moderate window since they don't have content-hashed names yet
# — when filenames change (e.g. styles.v2.css), bump the cache window.

# All paths — basic security headers
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Product images and category WebP variants — change rarely, cache one month
/assets/images/*
  Cache-Control: public, max-age=2592000

# CSS / JS — moderate cache; updates trickle out within a day. The
# Content-Type charset is explicit so browsers don't fall back to
# Windows-1252 on em-dashes and curly quotes.
/assets/css/*
  Cache-Control: public, max-age=86400, must-revalidate
  Content-Type: text/css; charset=utf-8
/assets/js/*
  Cache-Control: public, max-age=86400, must-revalidate
  Content-Type: application/javascript; charset=utf-8

# products.js is regenerated on every public-site deploy from D1, so we
# want the new version to land for visitors within minutes, not the next
# day. no-cache forces revalidation; the response is small (~80 KB) and
# 304 responses on unchanged builds keep this cheap.
/assets/js/products.js
  Cache-Control: public, no-cache, must-revalidate
  Content-Type: application/javascript; charset=utf-8

# Brand assets — favicons + footer logo + manifest
/favicon-16.png
  Cache-Control: public, max-age=2592000
/favicon-32.png
  Cache-Control: public, max-age=2592000
/apple-touch-icon.png
  Cache-Control: public, max-age=2592000
/icon-192.png
  Cache-Control: public, max-age=2592000
/icon-512.png
  Cache-Control: public, max-age=2592000
/Logo-footer.webp
  Cache-Control: public, max-age=2592000
/Logo.png
  Cache-Control: public, max-age=2592000
/og-card.jpg
  Cache-Control: public, max-age=86400
/site.webmanifest
  Cache-Control: public, max-age=86400

# HTML pages — always revalidate so new inline routing/filter logic is served
/
  Cache-Control: no-cache, max-age=0, must-revalidate
/*.html
  Cache-Control: no-cache, max-age=0, must-revalidate
/product/*.html
  Cache-Control: no-cache, max-age=0, must-revalidate

# Sitemap + robots — refresh frequently
/sitemap.xml
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=86400
