{
  "name": "klinemen-admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "K-LINE MEN admin dashboard — Preact SPA + Pages Functions on Cloudflare",
  "scripts": {
    "dev": "vite",
    "dev:full": "wrangler pages dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "wrangler pages deploy",
    "tail": "wrangler pages deployment tail",
    "db:create": "wrangler d1 create klinemen-cms",
    "db:migrate:local": "wrangler d1 migrations apply klinemen-cms --local",
    "db:migrate:prod": "wrangler d1 migrations apply klinemen-cms --remote",
    "db:seed:build": "node scripts/build-seed.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@preact/preset-vite": "^2.10.0",
    "preact": "^10.26.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  }
}
